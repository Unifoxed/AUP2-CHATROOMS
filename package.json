{
  "name": "AUP2-chat",
  "version": "1.0.0",
  "description": "Weird Chat",
  "author": "El Gatto",
  "main": "main.js",
  "scripts": {
    "start": "node server.js & electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.AUP2.chat",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "directories": {
      "output": "dist"
    },
    "asar": true
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^26.8.1"
  }
}